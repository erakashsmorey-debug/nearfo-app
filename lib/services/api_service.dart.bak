  // ===== FEED / POSTS =====

  /// GET /api/posts/feed — supports both page-based and cursor-based pagination
  static Future<FeedResponse> getFeed({
    String mode = 'mixed',
    int page = 1,
    int limit = 20,
    String? cursor,
  }) async {
    try {
      String url = '$_baseUrl/posts/feed?mode=$mode&limit=$limit';
      if (cursor != null) {
        url += '&cursor=$cursor';
      } else {
        url += '&page=$page';
      }
      final res = await http.get(Uri.parse(url), headers: _headers).timeout(_timeout);
      final data = jsonDecode(res.body);
      if (data['success'] == true && data['posts'] is List) {
        final posts = ((data['posts'] as List?) ?? [])
            .map((p) => PostModel.fromJson(p))
            .toList();
        return FeedResponse(
          posts: posts,
          hasMore: data['hasMore'] ?? false,
          nextCursor: data['nextCursor']?.toString(),
        );
      }
      return FeedResponse(posts: [], hasMore: false, error: data['message'] ?? 'Failed to load feed');
    } on TimeoutException {
      return FeedResponse(posts: [], hasMore: false, error: 'Request timed out.');
    } catch (e) {
      return FeedResponse(posts: [], hasMore: false, error: 'Network error: $e');
    }
  }

  /// Upload a single video to S3
  static Future<ApiResponse<String>> uploadVideo(String filePath, {String folder = 'videos'}) async {
    try {
      final fileName = filePath.split('/').last;
      final ext = filePath.split('.').last.toLowerCase();
      final mimeType = _getMediaType(ext);
      final contentType = '${mimeType.type}/${mimeType.subtype}';

      // Step 1: Get presigned S3 URL from backend
      final presignedUri = Uri.parse('$_baseUrl/upload/presigned?fileName=$fileName&fileType=$contentType&folder=$folder');
      final presignedRes = await http.get(presignedUri, headers: _headers).timeout(_timeout);
      final presignedData = jsonDecode(presignedRes.body);

      if (presignedData['success'] != true) {
        return ApiResponse.error(presignedData['message'] ?? 'Failed to get upload URL');
      }

      final presignedUrl = presignedData['presignedUrl'];
      final publicUrl = presignedData['publicUrl'];

      // Step 2: Upload video directly to S3 using presigned PUT URL
      // Use longer timeout for video uploads (videos can be large, especially on mobile data)
      final fileBytes = await File(filePath).readAsBytes();
      final fileSizeMB = fileBytes.length / (1024 * 1024);
      // Dynamic timeout: 120s base + 30s per MB (minimum 120s, max 600s)
      final uploadTimeoutSecs = (120 + (fileSizeMB * 30)).clamp(120, 600).toInt();
      debugPrint('[ApiService] Video upload: ${fileSizeMB.toStringAsFixed(1)}MB, timeout: ${uploadTimeoutSecs}s');
      // Must include Cache-Control header to match presigned URL params
      final isMedia = contentType.startsWith('image/') || contentType.startsWith('video/');
      final cacheControl = 'public, max-age=${isMedia ? 31536000 : 2592000}, immutable';
      final uploadRes = await http.put(
        Uri.parse(presignedUrl),
        headers: {
          'Content-Type': contentType,
          'Cache-Control': cacheControl,
        },
        body: fileBytes,
      ).timeout(Duration(seconds: uploadTimeoutSecs));

      if (uploadRes.statusCode == 200) {
        return ApiResponse.success(publicUrl);
      }
      return ApiResponse.error('Video upload to S3 failed (${uploadRes.statusCode})');
    } on TimeoutException {
      return ApiResponse.error('Request timed out. Please try again.');
    } catch (e) {
      return ApiResponse.error('Network error: $e');
    }
  }

  /// POST /api/posts
  static Future<ApiResponse<PostModel>> createPost({
    required String content,
    List<String>? images,
    String? video,
    String? mood,
    List<String>? hashtags,
    String visibility = 'public',
  }) async {
    try {
      final body = <String, dynamic>{
        'content': content,
        'images': images ?? [],
        'mood': mood ?? '',
        'hashtags': hashtags ?? [],
        'visibility': visibility,
      };
      if (video != null && video.isNotEmpty) {
        body['video'] = video;
      }

      final res = await http.post(
        Uri.parse('$_baseUrl/posts'),
        headers: _headers,
        body: jsonEncode(body),
      ).timeout(_timeout);
      final data = jsonDecode(res.body);
      if (data['success'] == true) {
        return ApiResponse.success(PostModel.fromJson(data['post']));
      }
      return ApiResponse.error(data['message'] ?? 'Failed to create post');
    } on TimeoutException {
      return ApiResponse.error('Request timed out. Please try again.');
    } catch (e) {
      return ApiResponse.error('Network error: $e');
    }
  }

