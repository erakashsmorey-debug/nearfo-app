            .map((r) => ReelModel.fromJson(r))
            .toList();
        final hasMore = data['hasMore'] ?? (data['pages'] != null ? page < data['pages'] : false);
        return ApiResponse.success(reels, hasMore: hasMore);
      }
      return ApiResponse.error(data['message'] ?? 'Failed to load saved reels');
    } on TimeoutException {
      return ApiResponse.error('Request timed out. Please try again.');
    } catch (e) {
      return ApiResponse.error('Network error: $e');
    }
  }

